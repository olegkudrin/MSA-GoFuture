@startuml C2_Fundamental

skinparam dpi 150

!include <C4/C4_Container>

title Платформа GoFuture (основная схема)

AddElementTag("legacy", $bgColor="DarkSlateBlue")
AddElementTag("domain", $bgColor="Teal")

System_Boundary(gofuture_platform, "GoFuture Platform") {

    ' Клиентские приложения
    Container(mobile_passenger, "Пассажирское приложение", "iOS/Android/Huawei", "Интерфейс для пассажиров")
    Container(mobile_driver, "Водительское приложение", "iOS/Android/Huawei", "Интерфейс для водителя")
    Container(web_corporate, "Корпоративный портал", "React/Vue.js", "Управление корпоративными поездками")
    Container(web_admin, "Админ-панель", "Web Application", "Управление платформой")

    ' Точка входа
    Container(api_gateway, "API Gateway", "AWS API Gateway", "Единая точка входа, маршрутизация, аутентификация")

    ' Авторизация доступа
    Container(identity_service, "Identity & Auth Service", "KeyCloak/Auth0", "Централизованная аутентификация")

    note as note3
    Identity & Auth Service используется и для внутренних нужд.
    end note

    ' Монолитное приложение
    Container(legacy_monolith, "Legacy Monolith", "Django", "Устаревшая логика, постепенно выводится", $tags="legacy")

    ' Доменные микросервисы
    Container(booking_service, "Booking Service", "Python/Go", "Управление бронированиями и оркестрация поездок", $tags="domain")
    Container(driver_service, "Driver Service", "Python/Go", "Управление водителями, статусами, доступностью", $tags="domain")
    Container(pricing_service, "Pricing Service", "Python/Go", "Динамическое ценообразование в реальном времени", $tags="domain")
    Container(payments_service, "Payments Service", "Python/Go", "Обработка платежей от пассажиров", $tags="domain")
    Container(payouts_service, "Payouts Service", "Python/Go", "Выплаты водителям", $tags="domain")
    Container(notification_service, "Notification Service", "Python/Go", "Отправка push-уведомлений", $tags="domain")
    Container(geography_service, "Geography Service", "Python/Go", "Геопоиск, маршрутизация, карты", $tags="domain")
    Container(analytics_service, "Analytics Service", "Python/Go", "Сбор и обработка аналитики", $tags="domain")
    Container(fraud_service, "Fraud Service", "Python/ML", "Обнаружение мошенничества с ML", $tags="domain")

    note as note1
    У каждого из девяти доменных микросервисов свой набор баз данных.
    end note

    ' Синхронные вызовы между сервисами
    Rel(booking_service,  driver_service,    "Поиск доступных водителей", "gRPC/HTTP")
    Rel(booking_service,  pricing_service,   "Расчет стоимости",          "gRPC/HTTP")
    Rel(booking_service,  geography_service, "Расчет маршрута",           "gRPC/HTTP")
    Rel(payments_service, fraud_service,     "Проверка на фрод",          "gRPC/HTTP")

    ' Инфраструктура обмена сообщениями
    ContainerQueue(event_bus, "Event Bus", "Apache Kafka", "Асинхронная коммуникация между сервисами")

    ' Связи клиентских приложений
    Rel(mobile_passenger, api_gateway, "HTTP/REST", "JSON")
    Rel(mobile_driver,    api_gateway, "HTTP/REST", "JSON")
    Rel(web_corporate,    api_gateway, "HTTP/REST", "JSON")
    Rel(web_admin,        api_gateway, "HTTP/REST", "JSON")

    ' Маршрутизация к монолитному приложению и доменным микросервисам
    Rel(api_gateway, legacy_monolith,   "Маршрутизирует legacy запросы", "HTTP")
    Rel(api_gateway, booking_service,   "Маршрутизирует /bookings",      "HTTP")
    Rel(api_gateway, driver_service,    "Маршрутизирует /drivers",       "HTTP")
    Rel(api_gateway, pricing_service,   "Маршрутизирует /pricing",       "HTTP")
    Rel(api_gateway, payments_service,  "Маршрутизирует /payments",      "HTTP")
    Rel(api_gateway, payouts_service,   "Маршрутизирует /payouts",       "HTTP")
    Rel(api_gateway, geography_service, "Маршрутизирует /geography",     "HTTP")
    Rel(api_gateway, analytics_service, "Маршрутизирует /analytics",     "HTTP")

    ' Обмен сообщениями монолитного приложения
    Rel(legacy_monolith, event_bus, "Публикует события во время миграции", "Kafka")
    Rel(event_bus, legacy_monolith, "Подписывается на события новых сервисов", "Kafka")

    ' Обмен сообщениями доменных микросервисов
    Rel(booking_service,      event_bus, "Публикует события бронирований и Saga", "Kafka")
    Rel(driver_service,       event_bus, "Публикует события водителей",           "Kafka")
    Rel(pricing_service,      event_bus, "Публикует события ценообразования",     "Kafka")
    Rel(payments_service,     event_bus, "Публикует события платежей",            "Kafka")
    Rel(payouts_service,      event_bus, "Публикует события выплат",              "Kafka")
    Rel(geography_service,    event_bus, "Публикует события маршрутизации",       "Kafka")
    Rel(fraud_service,        event_bus, "Публикует события фрода",               "Kafka")
    Rel(notification_service, event_bus, "Публикует события уведомлений",         "Kafka")
    '
    Rel(event_bus, notification_service, "Подписка на все события",               "Kafka")
    Rel(event_bus, analytics_service,    "Подписка на все доменные события",      "Kafka")
    Rel(event_bus, fraud_service,        "Подписка на бронирования и платежи",    "Kafka")
    Rel(event_bus, booking_service,      "Подписка на события Saga оркестрации",  "Kafka")

    ' Авторизация доступа
    Rel(api_gateway, identity_service, "Проверка JWT токенов", "OAuth 2.0")
}

' Пользователи
Person(passenger, "Пассажир", "Заказывает поездки")
Person(driver, "Водитель", "Принимает заказы")
Person(corporate_user, "Корпоративный клиент", "Управлялет корпоративными поездками")
Person(admin, "Администратор", "Управляет системой")

' Связи пользователей
Rel(passenger,      mobile_passenger, "Использует")
Rel(driver,         mobile_driver,    "Использует")
Rel(corporate_user, web_corporate,    "Использует")
Rel(admin,          web_admin,        "Управляет")

' Внешние системы
System_Ext(yandex_pay, "Payment Gateway", "Платежный шлюз")
System_Ext(yandex_maps, "Mapping Service", "Картографическия сервис")
System_Ext(fcm, "FCM", "Push-уведомления Google")
System_Ext(apns, "APNs", "Push-уведомления Apple")
System_Ext(huawei_push, "Huawei Push Kit", "Push-уведомления Huawei")
System_Ext(bank_api, "Banking APIs", "Банковские выплаты")

' Внешние интеграции
Rel(payments_service, yandex_pay, "Обработка платежей", "REST API")
Rel(geography_service, yandex_maps, "Геоданные и маршруты", "REST API")
Rel(notification_service, fcm, "Push Android", "REST API")
Rel(notification_service, apns, "Push iOS", "REST API")
Rel(notification_service, huawei_push, "Push Huawei", "REST API")
Rel(payouts_service, bank_api, "Выплаты водителям", "REST API")

@enduml
